{
  "mcpServers": {
    "gm-platform": {
      "type": "stdio",
      "command": "node",
      "args": [
        "/absolute/path/to/gm_platform/mcp_server_dev/dist/index.js"
      ],
      "env": {
        "GM_BASE_URL": "http://127.0.0.1:3000/api",
        "GM_LOGIN_ID": "op",
        "GM_PASSWORD": "1234"
      }
    }
  }
}
