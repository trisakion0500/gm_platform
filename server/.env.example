NODE_ENV=development

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=gm_platform

JWT_SECRET=your_jwt_secret_key
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=7d

# phone_number 암호화(AES-256-CBC) 키 — 32바이트 hex(64자). `npm run keygen`으로 생성
ENCRYPTION_KEY=your_64_char_hex_encryption_key

CORS_ALLOWED_ORIGINS=http://localhost:5173

PORT=3000

LOG_DEBUG_ERRORS=false

SWAGGER_ENABLED=true

# API 실행(S2S) 호출 타임아웃(ms) — 생략 시 기본값 10000
API_EXECUTION_TIMEOUT_MS=10000

# 로그인/회원가입 브루트포스 방지 리미터 — 생략 시 기본값 900000(15분)/10회
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10

# 만료된 user_session 정리 크론 표현식 — 생략 시 기본값 매일 새벽 4시(0 4 * * *)
SESSION_CLEANUP_CRON=0 4 * * *
